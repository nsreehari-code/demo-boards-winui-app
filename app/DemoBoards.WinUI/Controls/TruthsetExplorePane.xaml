<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DemoBoards_WinUI.Controls.TruthsetExplorePane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DemoBoards_WinUI.Controls"
    mc:Ignorable="d">

    <StackPanel Spacing="10">
        <Button x:Name="ToggleButton" Content="Truthset Explorer" Click="OnToggleClick" HorizontalAlignment="Stretch" />
        <Border x:Name="PaneBorder" Padding="12" CornerRadius="14" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="10">
                <TextBlock Text="Truthset Explore Pane" FontSize="18" FontWeight="SemiBold" />
                <TextBlock x:Name="CountText" Opacity="0.72" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="PrevButton" Content="Prev" Click="OnPrevClick" HorizontalAlignment="Left" />
                    <TextBlock x:Name="CurrentTitleText" Grid.Column="1" Margin="10,0" VerticalAlignment="Center" TextWrapping="WrapWholeWords" />
                    <Border x:Name="PhaseBadge" Grid.Column="2" Margin="8,0" Padding="8,2" CornerRadius="10" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="PhaseText" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock x:Name="CounterText" Grid.Column="3" Margin="10,0" VerticalAlignment="Center" Opacity="0.72" />
                    <Button x:Name="NextButton" Grid.Column="4" Content="Next" Click="OnNextClick" HorizontalAlignment="Right" />
                </Grid>
                <controls:CardRenderer x:Name="PreviewCard" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
