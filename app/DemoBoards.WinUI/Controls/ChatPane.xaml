<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DemoBoards_WinUI.Controls.ChatPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DemoBoards_WinUI.Controls"
    mc:Ignorable="d">

    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderRow" ColumnSpacing="8" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="HeaderTitleText" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button x:Name="PopoutButton" Grid.Column="1" Content="Open full chat" Click="OnPopoutClick" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <Button x:Name="HistoryButton" Content="Show previous messages" Click="OnLoadHistoryClick" HorizontalAlignment="Center" Visibility="Collapsed" />
                <StackPanel x:Name="HistoryHost" Spacing="10" />
                <StackPanel x:Name="MessagesHost" Spacing="10" />
                <Border x:Name="WorkingBubbleBorder" Padding="10" CornerRadius="12" Visibility="Collapsed">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="WorkingTitleText" FontWeight="SemiBold" />
                        <TextBlock x:Name="WorkingStatusText" Opacity="0.72" TextWrapping="WrapWholeWords" />
                        <StackPanel x:Name="WorkingDetailsHost" Spacing="6" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Spacing="6">
            <Border x:Name="DropZoneBorder" Padding="8" CornerRadius="12" AllowDrop="True" DragOver="OnComposerDragOver" Drop="OnComposerDrop">
                <StackPanel Spacing="6">
                    <TextBox x:Name="ComposerTextBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="84" PlaceholderText="Type a message" TextChanged="OnComposerTextChanged" />
                    <TextBlock x:Name="DropHintText" Opacity="0.6" Text="Drop files here or use Attach file to stage them for the next send." TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
            <StackPanel x:Name="AttachmentHost" Spacing="6" Visibility="Collapsed" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0" Opacity="0.72" TextWrapping="WrapWholeWords" VerticalAlignment="Center" />
                <Button x:Name="AttachButton" Grid.Column="1" Content="Attach File" Click="OnAttachClick" />
                <Button x:Name="SendButton" Grid.Column="2" Content="Send" Click="OnSendClick" />
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
