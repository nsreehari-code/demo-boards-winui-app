<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DemoBoards_WinUI.Controls.BoardCanvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock x:Name="BoardTitleText" FontSize="20" FontWeight="SemiBold" />
            <TextBlock x:Name="BoardSummaryText" Opacity="0.75" TextWrapping="WrapWholeWords" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollMode="Auto">
            <VariableSizedWrapGrid
                x:Name="CardsHost"
                Orientation="Horizontal"
                ItemWidth="320"
                ItemHeight="240" />
        </ScrollViewer>
    </Grid>
</UserControl>
