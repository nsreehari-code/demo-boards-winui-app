<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DemoBoards_WinUI.Controls.ChallengeConfirmModal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="12">
        <TextBlock x:Name="PromptText" TextWrapping="WrapWholeWords" />
        <TextBlock x:Name="ChallengeText" Opacity="0.78" TextWrapping="WrapWholeWords" />
        <StackPanel Spacing="6">
            <TextBox
                x:Name="AnswerTextBox"
                PlaceholderText="Enter the sum..."
                InputScope="Number"
                TextChanged="OnAnswerTextChanged"
                KeyDown="OnAnswerTextBoxKeyDown" />
            <TextBlock
                x:Name="ValidationText"
                Foreground="IndianRed"
                Opacity="0"
                Text="Incorrect - try again."
                TextWrapping="WrapWholeWords" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" Click="OnCancelClick" />
            <Button x:Name="ConfirmButton" Content="Confirm" Click="OnConfirmClick" IsEnabled="False" />
        </StackPanel>
    </StackPanel>
</UserControl>
