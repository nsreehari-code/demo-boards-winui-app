<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DemoBoards_WinUI.Controls.GandalfPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DemoBoards_WinUI.Controls"
    mc:Ignorable="d">

    <Grid>
        <controls:FloatingCircleButton
            x:Name="ToggleButton"
            IconGlyph="&#xE76C;"
            FloatPosition="TopLeft"
            Inset="0"
            OffsetX="-10"
            OffsetY="8"
            Diameter="48"
            ButtonStyle="{ThemeResource BoardEdgeToggleButtonStyle}"
            ToolTipText="Open Board Manager"
            Click="OnToggleClick" />
        <Border x:Name="PaneBorder" Margin="0,56,0,0" Padding="0" CornerRadius="14" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="0">
                <Grid Padding="16,14,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Board Manager" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource BoardAccentStrongBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="CountText" Grid.Column="1" FontSize="12" Opacity="0.72" VerticalAlignment="Center" />
                </Grid>
                <Grid Padding="16,12" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CurrentTitleText" Grid.Column="0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                    <Button x:Name="PrevButton" Grid.Column="1" Content="Prev" Click="OnPrevClick" HorizontalAlignment="Right" Style="{ThemeResource BoardToolbarButtonStyle}" />
                    <TextBlock x:Name="CounterText" Grid.Column="2" FontSize="12" Opacity="0.72" VerticalAlignment="Center" Margin="8,0" />
                    <Button x:Name="NextButton" Grid.Column="3" Content="Next" Click="OnNextClick" HorizontalAlignment="Right" Style="{ThemeResource BoardToolbarButtonStyle}" />
                </Grid>
                <controls:CardRenderer x:Name="PreviewCardView" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
