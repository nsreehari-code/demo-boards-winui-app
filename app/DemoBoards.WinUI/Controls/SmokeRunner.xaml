<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DemoBoards_WinUI.Controls.SmokeRunner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="10" MinWidth="760" MinHeight="520">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock Text="Smoke Runner" FontSize="20" FontWeight="SemiBold" />
            <TextBlock
                x:Name="StatusText"
                Opacity="0.72"
                Text="Run the embedded GoldenHarness smoke suite from inside the WinUI app."
                TextWrapping="WrapWholeWords" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="RunButton" Content="Run Tests" Click="OnRunClick" />
            </StackPanel>
        </StackPanel>

        <TextBox
            x:Name="OutputTextBox"
            Grid.Row="1"
            IsReadOnly="True"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            VerticalAlignment="Stretch"
            FontFamily="Consolas"
            PlaceholderText="Smoke output will appear here." />
    </Grid>
</UserControl>