<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DemoBoards_WinUI.Controls.PostboxCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DemoBoards_WinUI.Controls"
    mc:Ignorable="d">

    <Border x:Name="ShellBorder" Padding="14" CornerRadius="14" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <StackPanel Spacing="3">
                    <TextBlock x:Name="TitleText" FontSize="17" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="SubtitleText" FontSize="12" Opacity="0.68" TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border Padding="10" CornerRadius="12" Background="{ThemeResource BoardSurfaceStrongBrush}" BorderBrush="{ThemeResource BoardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Recent submissions" FontWeight="SemiBold" />
                        <TextBlock x:Name="HistoryStatusText" Opacity="0.68" TextWrapping="WrapWholeWords" />
                        <StackPanel x:Name="HistoryHost" Spacing="8" />
                    </StackPanel>
                </Border>

                <Border Padding="10" CornerRadius="12" Background="{ThemeResource BoardSurfaceStrongBrush}" BorderBrush="{ThemeResource BoardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Stored files" FontWeight="SemiBold" />
                        <StackPanel x:Name="FilesHost" Spacing="8" />
                    </StackPanel>
                </Border>

                <Border x:Name="UploadDropZoneBorder" Padding="10" CornerRadius="12" Background="{ThemeResource BoardAccentSoftBrush}" BorderBrush="{ThemeResource BoardBorderStrongBrush}" BorderThickness="1" AllowDrop="True" DragOver="OnUploadDragOver" Drop="OnUploadDrop">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Upload submission" FontWeight="SemiBold" />
                        <TextBlock x:Name="UploadDropHintText" Opacity="0.62" Text="Drop files here or browse to stage them for upload." TextWrapping="WrapWholeWords" />
                        <Button x:Name="BrowseFilesButton" Content="Browse Files" HorizontalAlignment="Left" />
                        <StackPanel x:Name="SelectedFilesHost" Spacing="6" Visibility="Collapsed" />
                        <TextBox x:Name="CommentTextBox" PlaceholderText="Add comment (optional)" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="68" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="UploadStatusText" Grid.Column="0" Opacity="0.68" TextWrapping="WrapWholeWords" VerticalAlignment="Center" />
                            <Button x:Name="UploadButton" Grid.Column="1" Content="Upload" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="10" CornerRadius="12" Background="{ThemeResource BoardSurfaceMutedBrush}" BorderBrush="{ThemeResource BoardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Live conversation" FontWeight="SemiBold" />
                        <controls:ChatPane x:Name="ChatPaneView" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
