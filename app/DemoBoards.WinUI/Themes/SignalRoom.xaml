<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BoardColorBg">#FF08111F</Color>
    <Color x:Key="BoardColorBgElevated">#FF0D1728</Color>
    <Color x:Key="BoardColorSurface">#EB111B2E</Color>
    <Color x:Key="BoardColorSurfaceStrong">#FA152238</Color>
    <Color x:Key="BoardColorSurfaceMuted">#D10E1829</Color>
    <Color x:Key="BoardColorBorder">#2E6E9AD7</Color>
    <Color x:Key="BoardColorBorderStrong">#577AADFF</Color>
    <Color x:Key="BoardColorText">#FFE5EEFC</Color>
    <Color x:Key="BoardColorTextMuted">#FF94A9C6</Color>
    <Color x:Key="BoardColorTextSoft">#FF7387A2</Color>
    <Color x:Key="BoardColorAccent">#FF54A6FF</Color>
    <Color x:Key="BoardColorAccentStrong">#FF7DC7FF</Color>
    <Color x:Key="BoardColorAccentSoft">#2954A6FF</Color>
    <Color x:Key="BoardColorOverlay">#C2040A13</Color>
    <Color x:Key="BoardStatusRunningColor">#FFF2B462</Color>
    <Color x:Key="BoardStatusCompletedColor">#FF2ED1A2</Color>
    <Color x:Key="BoardStatusFailedColor">#FFFF6B81</Color>
    <Color x:Key="BoardStatusBlockedColor">#FFF2B84B</Color>
    <Color x:Key="BoardStatusFreshColor">#FF8EA6C4</Color>
    <Color x:Key="BoardStatusUnknownColor">#FF7D8FA8</Color>

    <LinearGradientBrush x:Key="BoardWindowBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF09111F" Offset="0" />
        <GradientStop Color="#FF07101B" Offset="0.52" />
        <GradientStop Color="#FF060D17" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BoardTopBarBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F00D1728" Offset="0" />
        <GradientStop Color="#E009121F" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="BoardTopBarBorderBrush" Color="{StaticResource BoardColorBorderStrong}" />
    <SolidColorBrush x:Key="BoardTextBrush" Color="{StaticResource BoardColorText}" />
    <SolidColorBrush x:Key="BoardTextMutedBrush" Color="{StaticResource BoardColorTextMuted}" />
    <SolidColorBrush x:Key="BoardTextSoftBrush" Color="{StaticResource BoardColorTextSoft}" />
    <SolidColorBrush x:Key="BoardBorderBrush" Color="{StaticResource BoardColorBorder}" />
    <SolidColorBrush x:Key="BoardBorderStrongBrush" Color="{StaticResource BoardColorBorderStrong}" />
    <SolidColorBrush x:Key="BoardAccentBrush" Color="{StaticResource BoardColorAccent}" />
    <SolidColorBrush x:Key="BoardAccentStrongBrush" Color="{StaticResource BoardColorAccentStrong}" />
    <SolidColorBrush x:Key="BoardAccentSoftBrush" Color="{StaticResource BoardColorAccentSoft}" />
    <SolidColorBrush x:Key="BoardOverlayBrush" Color="{StaticResource BoardColorOverlay}" />
    <SolidColorBrush x:Key="BoardSurfaceStrongBrush" Color="{StaticResource BoardColorSurfaceStrong}" />
    <SolidColorBrush x:Key="BoardSurfaceMutedBrush" Color="{StaticResource BoardColorSurfaceMuted}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource BoardColorSurface}" />
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource BoardColorSurfaceStrong}" />
    <SolidColorBrush x:Key="BoardCanvasPanelBrush" Color="#F0152238" />
    <SolidColorBrush x:Key="BoardCanvasPanelBorderBrush" Color="#666E9AD7" />
    <SolidColorBrush x:Key="BoardCanvasMiniMapBrush" Color="#F2111B2E" />
    <SolidColorBrush x:Key="BoardCanvasMiniMapBorderBrush" Color="#666E9AD7" />
    <SolidColorBrush x:Key="BoardCanvasMiniMapViewportBrush" Color="#2954A6FF" />
    <SolidColorBrush x:Key="BoardCanvasMiniMapViewportBorderBrush" Color="#CC7DC7FF" />
</ResourceDictionary>