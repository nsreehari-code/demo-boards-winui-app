{
  "repoRoot": "${repoRoot}",
  "frontend": {
    "defaultBoardId": "live",
    "serverUrl": "http://localhost:7799",
    "boardServerConstants": {
      "agentOutputChannel": "agent-output",
      "agentToolsChannel": "agent-tools"
    },
    "canvasLayout": {
      "defaultCardWidth": 360,
      "defaultCardHeight": 240,
      "columnGap": 420,
      "rowGap": 280,
      "originX": 40,
      "originY": 40
    }
  },
  "backend": {
    "nsCodeRepoRoot": "${repoRoot}/demo-boards-ns-code",
    "agentfacePort": 7799,
    "requireFixedAgentfacePort": true,
    "hostConfigPath": "${nsCodeRepoRoot}/demo-board/server/hosted-board-runtime/hosted-board-runtime.localfs.config.json",
    "templatesConfigPath": "${nsCodeRepoRoot}/demo-board/server/hosted-board-runtime/templates-config.json",
    "localFsConfigLoaderPath": "${nsCodeRepoRoot}/demo-board/server/hosted-board-runtime/localfs-adapter/load-config.js",
    "hostedPrestartScriptPath": "${nsCodeRepoRoot}/demo-board/server/hosted-board-runtime/scripts/prestart.js",
    "setupSingleAiWorkspaceScriptPath": "${nsCodeRepoRoot}/demo-board/server/hosted-board-runtime/scripts/setup-single-ai-workspace.js",
    "assistantRegistryPath": "${nsCodeRepoRoot}/demo-board/server/chat-flow/assistant_registry.json"
  }
}