<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DemoBoards_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DemoBoards_WinUI.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource BoardWindowBackgroundBrush}">
        <Grid RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="14,6,14,6" Background="{ThemeResource BoardTopBarBackgroundBrush}" BorderBrush="{ThemeResource BoardTopBarBorderBrush}" BorderThickness="0,0,0,1">
                <Grid ColumnSpacing="10" MinHeight="48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="1" VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText" FontSize="15" FontWeight="Bold" Foreground="{ThemeResource BoardTextBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="PageSubtitleText" FontSize="11" Opacity="0.92" Foreground="{ThemeResource BoardTextMutedBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <controls:TimerButton x:Name="RefreshTimerButton" Click="OnRefreshClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <controls:MainBoard Grid.Row="1" x:Name="MainBoardView" />
        </Grid>

        <controls:GlobalModal x:Name="InspectModalView" />
        <controls:GlobalModal x:Name="ConfigModalView" />
        <controls:GlobalModal x:Name="ChatModalView" />
        <controls:GlobalModal x:Name="SmokeModalView" />
        <controls:FloatingCircleButton
            x:Name="BoardConfigButton"
            SvgIconPath="Assets/Icons/appconfig-settings.svg"
            FloatPosition="BottomRight"
            Inset="18"
            Diameter="48"
            ToolTipText="Board config"
            Click="OnBoardConfigClick" />

        <Grid x:Name="StartupOverlay" Background="{ThemeResource BoardWindowBackgroundBrush}">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24"
                CornerRadius="18"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <StackPanel Spacing="14" Width="320">
                    <ProgressRing IsActive="True" Width="40" Height="40" HorizontalAlignment="Center" />
                    <TextBlock
                        Text="Loading DemoBoards"
                        FontSize="22"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource BoardTextBrush}" />
                    <TextBlock
                        x:Name="StartupStatusText"
                        Text="Preparing board surface..."
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Foreground="{ThemeResource BoardTextMutedBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
