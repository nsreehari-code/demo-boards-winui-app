<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DemoBoards_WinUI.FrePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource BoardWindowBackgroundBrush}">
        <Border
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="28"
            CornerRadius="20"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <StackPanel Spacing="18" Width="360">
                <TextBlock
                    Text="DemoBoards"
                    FontSize="32"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource BoardTextBrush}" />
                <TextBlock
                    Text="Launch the board canvas only when you are ready to enter the runtime surface."
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords"
                    Foreground="{ThemeResource BoardTextMutedBrush}" />
                <Button
                    x:Name="EnterBoardButton"
                    Content="Enter the Board"
                    HorizontalAlignment="Center"
                    Padding="20,10"
                    Click="OnEnterBoardClick" />
            </StackPanel>
        </Border>
    </Grid>
</Page>