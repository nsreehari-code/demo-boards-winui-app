{
  "name": "demo-boards-winui-app",
  "private": true,
  "type": "module",
  "scripts": {
    "goldenharness": "node ./scripts/dotnet.mjs run --project app/engines/GoldenHarness/GoldenHarness.csproj",
    "validatorharness": "node ./scripts/dotnet.mjs run --project app/engines/ValidatorHarness/ValidatorHarness.csproj",
    "converterharness": "node ./scripts/dotnet.mjs run --project app/engines/ConverterHarness/ConverterHarness.csproj",
    "renderharness": "node ./scripts/dotnet.mjs run --project app/DemoBoards.WinUI/DemoBoards.WinUI.csproj -- --render-harness",
    "hooksharness": "node ./scripts/dotnet.mjs run --project app/DemoBoards.WinUI/DemoBoards.WinUI.csproj -- --hooks-harness",
    "my-http:winui:headless": "node ./scripts/run-my-http-winui-headless.mjs",
    "winui:guard:xaml": "node ./scripts/check-xaml-drift.mjs",
    "prewinui:build": "npm run winui:guard:xaml",
    "prewinui:start": "npm run winui:guard:xaml",
    "prewinui:restart": "npm run winui:guard:xaml",
    "winui:stop": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-winui.ps1",
    "winui:build": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-winui.ps1",
    "winui:clean": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/clean-winui.ps1",
    "winui:start": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-winui.ps1",
    "winui:restart": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/restart-winui.ps1",
    "winui:ui-smoke": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-winui-ui-smoke.ps1",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}